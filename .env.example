# Copy this file to .env and fill in your values
DVLA_API_KEY=
DVSA_MOT_API_KEY=
PLATE_TO_VIN_API_KEY=
REDIS_URL=
PORT=3000
NODE_ENV=development

# eBay Partner Network (EPN) — https://partnernetwork.ebay.co.uk/
EBAY_CAMPAIGN_ID=

# Awin affiliate — https://www.awin.com/
# Publisher ID from your Awin account dashboard
AWIN_AFFILIATE_ID=
# Merchant IDs (defaults pre-filled; override only if changed)
AWIN_AUTOTRADER_MERCHANT_ID=3441
AWIN_MOTORS_MERCHANT_ID=10966
AWIN_AUTOSCOUT24_FR_MERCHANT_ID=15483

# France — SIV plate lookup (RapidAPI: immatriculation-api)
# https://rapidapi.com/api-immatriculation/api/immatriculation-api
FR_PLATE_API_KEY=
FR_PLATE_API_URL=https://immatriculation-api.p.rapidapi.com/
FR_PLATE_RAPIDAPI_HOST=immatriculation-api.p.rapidapi.com
